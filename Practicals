      "source": [
        "#multiple linear regression - Normal equation \n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "\n",
        "data = pd.read_csv(\"Student_Performance.csv\")\n",
        "print(data.head())\n",
        "\n",
        "data[\"Extracurricular Activities\"] = data[\"Extracurricular Activities\"].map({\"Yes\": 1, \"No\": 0})\n",
        "\n",
        "\n",
        "X = data[[\"Hours Studied\", \"Previous Scores\", \"Extracurricular Activities\",\n",
        "          \"Sleep Hours\", \"Sample Question Papers Practiced\"]].values\n",
        "y = data[\"Performance Index\"].values\n",
        "\n",
        "\n",
        "X_b = np.c_[np.ones((X.shape[0], 1)), X]\n",
        "\n",
        "theta_best = np.linalg.inv(X_b.T.dot(X_b)).dot(X_b.T).dot(y) #θ=(X^TX)^−1X^Ty\n",
        "print(\"Parameters (Intercept + Coefficients):\", theta_best)\n",
        "\n",
        "# Predictions\n",
        "y_pred = X_b.dot(theta_best)\n",
        "\n",
        "# Example prediction\n",
        "sample = np.array([1, 8, 90, 1, 7, 4])  # 1=intercept, Hours=8, Prev=90, Extra=1, Sleep=7, Papers=4\n",
        "pred_score = sample.dot(theta_best)\n",
        "print(f\"Predicted Performance Index for given student: {pred_score}\")\n",
        "\n"
      ]
