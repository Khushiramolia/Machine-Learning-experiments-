        "#MULTIPLE LINEAR REGRESSION USING STOCASTIC GD\n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "data = pd.read_csv(\"Student_Performance.csv\")\n",
