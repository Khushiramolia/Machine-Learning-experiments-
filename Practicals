        "# Add intercept column\n",
        "X_b = np.c_[np.ones((X.shape[0], 1)), X]  # shape: (n_samples, n_features+1)\n",
        "\n",
        "def stochastic_gradient_descent(X, y, learning_rate=0.01, n_epochs=50):\n",
        "    m, n = X.shape\n",
        "    theta = np.zeros(n)  \n",
        "    cost_history = []\n",
